{
  "title": "Home Server",
  "uid": "home-server",
  "schemaVersion": 39,
  "refresh": "10s",
  "panels": [

    { "type": "text", "id": 20, "title": "System",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "options": { "mode": "markdown", "content": "" } },

    {
      "type": "gauge", "title": "CPU Usage", "id": 1,
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 5 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/^total$/", "values": false },
        "minVizWidth": 75, "minVizHeight": 75, "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 60 },
            { "color": "red", "value": 85 }
          ]}
        }, "overrides": []
      },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "glances" },
      "targets": [{
        "refId": "A", "type": "json", "source": "url",
        "url": "/api/4/cpu", "url_options": { "method": "GET" },
        "parser": "backend", "root_selector": "",
        "columns": [
          { "selector": "total",   "text": "total",   "type": "number" },
          { "selector": "user",    "text": "user",    "type": "number" },
          { "selector": "system",  "text": "system",  "type": "number" },
          { "selector": "cpucore", "text": "cpucore", "type": "number" }
        ]
      }]
    },

    {
