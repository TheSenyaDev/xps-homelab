# Secrets
.env
cloudflared/credentials.json

# Private keys
*.key
*.pem
*.p12
*.pfx

# Databases
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Backup files
*.bak

# Log files
*.log
*.log.old

# Portainer — runtime data and keys
portainer/data/

# Homarr — runtime database and generated config
homarr/data/

# Uptime Kuma — runtime database
uptime-kuma/data/

# Obsidian — entire runtime config (cookies, session, cache, certs)
obsidian/config/
obsidian/vaults/

# Grafana — persistent data volume (managed by Docker)
grafana/data/

# Claude desktop — browser profile and session data
claude-code/config/

# Daily notes
senya-daily/data

# Authelia — runtime state (the config files themselves are kept in git)
authelia/db.sqlite3
authelia/notification.txt
# Vaultwarden — vault database, attachments, keys (NEVER commit)
vaultwarden/data/

# Obsidian LiveSync CouchDB — database files
obsidian-couchdb/data/

# Finance app — SQLite database
senya-finance/data/
